MMRAG_VECTOR_BACKEND=faiss
MMRAG_STORAGE_DIR=.rag_store
MMRAG_COLLECTION=default

# Optional: OpenAI models for generation and vision captioning
MMRAG_OPENAI_API_KEY=
MMRAG_CHAT_MODEL=gpt-4.1-mini
MMRAG_VISION_MODEL=gpt-4.1-mini
MMRAG_TEXT_EMBEDDING_MODEL=text-embedding-3-small

# Optional: remote or embedded qdrant
MMRAG_QDRANT_URL=
MMRAG_QDRANT_API_KEY=
MMRAG_QDRANT_PATH=.rag_store/qdrant
