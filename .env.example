MMRAG_VECTOR_BACKEND=faiss
MMRAG_STORAGE_DIR=.rag_store
MMRAG_COLLECTION=default
MMRAG_DEFAULT_TENANT=public
MMRAG_CHUNK_SIZE=900
MMRAG_CHUNK_OVERLAP=140
MMRAG_INGESTION_SKIP_UNCHANGED_FILES=true
MMRAG_ADAPTIVE_CHUNKING_ENABLED=true
MMRAG_ADAPTIVE_CHUNKING_MIN_SIZE=280
MMRAG_ADAPTIVE_CHUNKING_TABLE_FACTOR=0.58
MMRAG_ADAPTIVE_CHUNKING_PROCEDURAL_FACTOR=0.78
MMRAG_ADAPTIVE_CHUNKING_NARRATIVE_FACTOR=1.0
MMRAG_ADAPTIVE_CHUNKING_OVERLAP_FACTOR=0.8

# Optional: OpenAI models for generation and vision captioning
MMRAG_OPENAI_API_KEY=
MMRAG_CHAT_MODEL=gpt-4.1-mini
MMRAG_VISION_MODEL=gpt-4.1-mini
MMRAG_TEXT_EMBEDDING_MODEL=text-embedding-3-small

# Retrieval tuning
MMRAG_RETRIEVAL_TOP_K_PER_MODALITY=4
MMRAG_RETRIEVAL_TOP_K_LEXICAL=12
MMRAG_RETRIEVAL_RRF_K=60
MMRAG_RETRIEVAL_RRF_WEIGHT_TEXT=1.0
MMRAG_RETRIEVAL_RRF_WEIGHT_TABLE=1.0
MMRAG_RETRIEVAL_RRF_WEIGHT_IMAGE=1.0
MMRAG_RETRIEVAL_RRF_WEIGHT_LEXICAL=1.0
MMRAG_RETRIEVAL_ENABLE_RERANKER=false
MMRAG_RETRIEVAL_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
MMRAG_RETRIEVAL_RERANK_CANDIDATES=20
MMRAG_RETRIEVAL_ENABLE_RESULT_DIVERSITY=true
MMRAG_RETRIEVAL_MAX_CHUNKS_PER_SOURCE=3
MMRAG_RETRIEVAL_DUPLICATE_SIMILARITY_THRESHOLD=0.9
MMRAG_RETRIEVAL_AUTO_CORRECT_ENABLED=true
MMRAG_RETRIEVAL_AUTO_CORRECT_MIN_HITS=3
MMRAG_RETRIEVAL_AUTO_CORRECT_MIN_UNIQUE_SOURCES=2
MMRAG_RETRIEVAL_AUTO_CORRECT_MIN_UNIQUE_MODALITIES=2
MMRAG_RETRIEVAL_AUTO_CORRECT_TARGET_MODE=hybrid_rerank
MMRAG_RETRIEVAL_AUTO_CORRECT_TOP_K_MULTIPLIER=2.0
MMRAG_RETRIEVAL_AUTO_CORRECT_LEXICAL_MULTIPLIER=2.0

# Optional: multi-tenant API key auth for REST API
MMRAG_AUTH_ENABLED=false
MMRAG_AUTH_API_KEY_HEADER=X-API-Key
MMRAG_AUTH_TENANT_HEADER=X-Tenant-ID
MMRAG_AUTH_TENANT_API_KEYS=tenant-a:key-a,tenant-b:key-b

# Optional: remote or embedded qdrant
MMRAG_QDRANT_URL=
MMRAG_QDRANT_API_KEY=
MMRAG_QDRANT_PATH=.rag_store/qdrant
